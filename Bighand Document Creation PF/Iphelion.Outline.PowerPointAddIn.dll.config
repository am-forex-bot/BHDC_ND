				<bindingRedirect oldVersion="0.0.0.0-1.0.1823.32" newVersion="1.0.1823.32" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="Microsoft.Web.WebView2.Wpf" publicKeyToken="2a8ab48044d2601e" culture="neutral" />
