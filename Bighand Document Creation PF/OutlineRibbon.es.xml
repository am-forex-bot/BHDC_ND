<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="RibbonLoad"
					xmlns:outline="Iphelion.Outline.CustomUI"
		xmlns:mso="http://schemas.microsoft.com/office/2009/07/customui"
		loadImage="LoadImage">
	<commands>
		<command idMso="FileNewDefault" onAction="FileNewOverride"/>
		<command idMso="PrintPreviewAndPrint" onAction="FilePrintOverride"/>
	</commands>
	<ribbon startFromScratch="false">
		<tabs>
			<tab idQ="outline:TabOutline" label="Document Creation" insertAfterMso="TabHome" keytip="X">
				<group idQ="outline:GrpAuthor" label="Autor" insertBeforeQ="outline:GrpDesigner">
					<dropDown id="DdAuthor" onAction="DdAuthorOnAction" label="Autor" showImage="true"
										image="Icon_16_AuthorList" sizeString="1234567812345678" getItemCount="DdAuthorGetItemCount"
										getItemLabel="DdAuthorGetItemLabel" getSelectedItemIndex="DdAuthorGetSelectedItemIndex"
										screentip="Clicar el desplegable para seleccionar un autor diferente" keytip="A" />
					<dropDown id="DdOffice" onAction="DdOfficeOnAction" label="Oficina" showImage="true" image="Icon_16_Office"
										sizeString="1234567812345678" getItemCount="DdOfficeGetItemCount" getItemLabel="DdOfficeGetItemLabel"
										getSelectedItemIndex="DdOfficeGetSelectedItemIndex" screentip="Clicar el desplegable para seleccionar una oficina diferente" keytip="O" />
					<!--<dropDown id="DdEntity" onAction="DdEntityOnAction" label="Entidad" showImage="true" image="Icon_16_Entity"
										sizeString="1234567812345678" getItemCount="DdEntityGetItemCount" getItemLabel="DdEntityGetItemLabel"
										getSelectedItemIndex="DdEntityGetSelectedItemIndex" screentip="Clicar el desplegable para seleccionar una entidad diferente" keytip="E" />-->
					<dropDown id="DdLanguage" onAction="DdLanguageOnAction" label="Idioma" showImage="true"
										image="Icon_16_Languages" sizeString="1234567812345678" getItemCount="DdLanguageGetItemCount"
										getItemLabel="DdLanguageGetItemLabel" getSelectedItemIndex="DdLanguageGetSelectedItemIndex"
										screentip="Clicar el desplegable para seleccionar un idioma diferente" keytip="G" />
					<dialogBoxLauncher>
						<button id="EditAuthors" onAction="EditAuthorsOnAction" screentip="Editar la lista de autores" keytip="U" />
					</dialogBoxLauncher>
				</group>
				<group idQ="outline:GrpWizard" insertBeforeQ="outline:GrpDesigner">
					<button id="ShowFormButton" image="Icon_32_TemplateWizard" label="Mostrar Asistente" onAction="ShowFormOnAction"
									size="large" getEnabled="ShowWizardGetEnabled" keytip="W" />
					<!--<button id="ShowSmartBlockFormButton" image="Icon_32_TemplateWizard" label="Mostrar Smart Blocks" onAction="ShowSmartBlockFormOnAction"
									size="large" getEnabled="ShowSmartBlockFormGetEnabled" keytip="SB" />-->
				</group>
				<group idQ="outline:GrpTemplates" label="Plantillas" insertBeforeQ="outline:GrpDesigner">
					<!--<button id="BtnLetter" image="Icon_32_Template" onAction="OpenTemplateAction"
									tag="Letter.dotx" label="Carta" screentip="Crear una carta utilizando los detalles del autor actual" size="large" keytip="L" />
					<button id="BtnEnvelope" image="Icon_32_EnvelopeCreationV2" onAction="OpenTemplateAction"
									tag="Envelope.dotx" label="Sobre" screentip="Crear un sobre" size="large" keytip="E" />-->
					<button id="BtnOther" image="Icon_32_OtherTemplates" onAction="OpenOtherAction" label="Todas las Plantillas"
									screentip="Mostrar la lista de todas las plantillas" size="large" keytip="T" />
					<button id="BtnFromExistingWithContent"  image="Icon_64_Recycle" label="Crear de existente" size="large" keytip="CE"
									onAction="OpenOtherWithCopyAndContentAction" getEnabled="HasActiveDocumentCallback" screentip="Crear un documento nuevo y pase los datos" />
					<!--<button id="BtnNewVersion"  image="Icon_32_CopyItem" label="Crear versión nueva" size="large" keytip="CV"
									onAction="CreateVersionWithCopyAndContentAction" getEnabled="HasActiveDocumentCallback" screentip="Crear una versión nueva del documento" />-->
				</group>
				<group idQ="outline:GrpFavourites" label=" " insertBeforeQ="outline:GrpDesigner">
					<dynamicMenu id="BtnFavourites" size="large" image="Icon_32_FavouritesStar" label="Favoritos" getContent="BtnFavouritesGetContent" screentip="Mostrar la lista de plantillas favoritas" keytip="F" />
					<dialogBoxLauncher>
						<button id="BtnTemplateFavs" screentip="Seleccionar las plantillas favoritas" onAction="SelectFavouritesOnAction" label="Favoritos" keytip="V" />
					</dialogBoxLauncher>
				</group>
				<group idQ="outline:GrpPrint" label=" " insertBeforeQ="outline:GrpDesigner">
					<button id="BtnPrint" size="large" image="Icon_32_PrinterDialog" label="Impresión Inteligente" onAction="BtnPrintOnAction"
									getEnabled="CustomPrintGetEnabled" keytip="P" />
					<button id="BtnManualPrint" size="large" image="Icon_32_PrinterDialog" label="Impresión Manual" onAction="BtnManualPrintOnAction"
														 getEnabled="CustomPrintGetEnabled" keytip="CP" />
					<dialogBoxLauncher>
						<button id="BtnPrinterSettings2" label="Preferencias de Impresión" onAction="BtnPrinterSettingsOnAction" screentip="Establecer las preferencias de impression" keytip="R" />
					</dialogBoxLauncher>
				</group>
				<group idQ="outline:GrpContent" label="Contenido" insertBeforeQ="outline:GrpDesigner" >
					<!--<mso:control idQ="mso:CustomGallery2" size="large" label="Cláusulas de Certificación" screentip="Cláusula de Certificación" />-->
					<menu id="mnuInsertOther" label="Añadir/Quitar Contenido" size="large" image="Icon_32_AddField" keytip="C" >
						<button id="BtnInsertDate"  image="Icon_16_DateField" label="Fecha" onAction="RunCommandAction" getEnabled="RunCommandEnabled" tag="insertFormattedDate" screentip="Insertar fecha con formato en la posición del cursor" />
						<button id="BtnInsertDmsId" image="Icon_16_AddDocRef" label="Insertar Ref DMS" onAction="RunCommandAction" getEnabled="RunCommandEnabled" tag="insertDmsId" screentip="Insertar referencia DMS en la posición del cursor" />
						<menuSeparator id="sep1" />
						<button id="BtnInsertDraft" label="Insertar Línea de Borrador" image="Icon_16_AddDocRef" onAction="RunCommandAction" getEnabled="RunCommandEnabled" getVisible="RunCommandVisible" tag="updateDraftLine" screentip="Insertar o actualizar la línea de borrador del documento" />
						<button id="BtnRemoveDraft" label="Quitar línea de Borrador" image="Icon_16_ReferenceRemoval" onAction="RunCommandAction" getEnabled="RunCommandEnabled" getVisible="RunCommandVisible" tag="removeDraftLine" screentip="Quitar la línea de borrador del documento" />
					</menu>
					<button id="BtnBidLibrary" size="large" image="Icon_32_AddField" label="Biblioteca de Contenido" onAction="ToggleClauseBankOnAction" getEnabled="HasActiveDocumentCallback" tag="bidLibrary" />

					<button id="ShowEndnotesButton" image="Icon_32_Endnotes" label="Mostrar Notas al Final" onAction="ShowEndnotesOnAction"
									size="large" keytip="NO" getEnabled="HasActiveDocumentCallback" />
					<button id="InsertDateButton" image="Icon_32_DateField" label="Insertar la Fetcha" onAction="InsertDateOnAction"
									size="large" keytip="ID" getEnabled="HasActiveDocumentCallback" />

					<!--<dropDown id="DdInsertToc" onAction="DdInsertTocAction" showImage="false" getVisible="SelectTocVisible"
											sizeString="1234567812345678" getItemCount="DdInsertTocGetItemCount" getEnabled="InsertTocEnabled"
											getItemLabel="DdInsertTocGetItemLabel" getSelectedItemIndex="DbInsertTocGetSelectedItemIndex"
											screentip="Haz clic en el desplegable para seleccionar una configuración de la TdC diferente" keytip="T" />
					<button id="BtnInsertToc" size="large" image="Icon_32_TOC" label="Insertar TdC" onAction="BtnInsertTocAction" getVisible="InsertTocVisible" getEnabled="InsertTocEnabled" />-->

					<!--<splitButton id="BtnDocIdOptions" size="large" getVisible="InsertDocIdVisible" getEnabled="InsertDocIdEnabled">
						<button id="BtnInsertDocId" image="Icon_64_AddDocRef" label="Opciones de Doc ID" onAction="BtnInsertDocIdAction" />
						<menu id="MnuInsertDocId">
							<button id="BtnRemoveDocId" image="Icon_64_ReferenceRemoval" label="Eliminar Doc ID" onAction="BtnRemoveDocIdAction" />
						</menu>
					</splitButton>-->
					
					<!--<gallery id="GalApplyStyles" showItemLabel="true" image="Icon_32_HouseStyle" size="large" label="Aplicar Estilos" columns="1"
									 itemHeight="125" itemWidth="575" screentip="Cambiar el estilo del documento" supertip="Cambiar los estilos de las enumeraciones en el documento"
									 getEnabled="ApplyStylesGetEnabled" getItemCount="ApplyStylesItemCount" getVisible="ApplyStylesVisible"
									 getItemID="ApplyStylesGetItemId" getItemLabel="ApplyStylesGetItemLabel" getItemImage="ApplyStylesGetItemImage" onAction="ApplyStylesOnAction">
						<button id="BtnCurrentStyles" imageMso="Info" getLabel="CurrentStyleSetGetLabel" getEnabled="ApplyStylesGetEnabled" getVisible="ApplyStylesVisible"/>
					</gallery>-->
				</group>
				<group idQ="outline:DocOptions" label="Documento" insertBeforeQ="outline:GrpDesigner">
					<!--<editBox id="QuickOpen" label="Abierta Rápida" imageMso="FileOpen" onChange="RunCommandActionOnChange" getEnabled="RunCommandEnabled" screentip="Introduzca un WorkSite número de documento para abrir" keytip="OO" tag="openDmsDocument" />-->
					<!--<button id="EditProfile" size="normal" label="Editar Perfil" onAction="RunCommandAction" getEnabled="RunCommandEnabled" screentip="Editar el documento WorkSite perfil" keytip="OP" tag="editDmsProfile" />-->
					<button id="BtnMailMerge" size="large" imageMso="MailMergeFieldFormatMenu" label="Actualizar para fusión de datos" onAction="MailMergeOnAction" screentip="Preparar el documento para fusión de datos" keytip="M" />
					<mso:control idQ="mso:FileSaveAsPdfOrXps" size="large" label="Guardar como PDF" screentip="Guardar documento como PDF" keytip="S" />
				</group>
				<group idQ="outline:GrpHelp" label=" " insertBeforeQ="outline:GrpDesigner">
					<button id="BtnOptions" size="large" image="Icon_32_Prefs" label="Opciones" onAction="ShowOptionsOnAction" screentip="Abrir Opciones" keytip="Q" />
					<button id="BtnHelp" size="large" image="Icon_64_Help" label="Ayuda" onAction="ShowHelpOnAction" screentip="Abrir Ayuda" keytip="H" />
					<dialogBoxLauncher>
						<button id="AboutOutline" screentip="Acerca de Document Creation" onAction="AboutOutline" keytip="B" />
					</dialogBoxLauncher>
				</group>
			</tab>
		</tabs>
	</ribbon>
