                  name="Contact SQL Search" connectionStringName="ContactSearchSqlConnector"
                  queryByIdFilename="ContactSqlConnectorQuery-ById.sql" queryByNameFilename="ContactSqlConnectorQuery-ByLastName.sql"
                  title ="Contact SQL Search" description ="Search by last name"/>-->
    <!--<connector id="DYNAMICS" name="Dynamics Connector" assembly="Iphelion.Outline.Integration.Dynamics.dll" typeName="Iphelion.Outline.Integration.Dynamics.DynamicsContactSearch" templateName="NameCompanyAndAddressTemplate" />-->
    <!--<connector id="AUTHOR" assembly="Iphelion.Outline.Controls.dll" typeName="Iphelion.Outline.Controls.Search.AuthorContactSearch"/>-->
    <!--<connector id="ONEPLACE" name="OnePlace" assembly="BigHand.Outline.Integration.OnePlace.dll" typeName="BigHand.Outline.Integration.OnePlace.OnePlaceContactSearch" templateName="NameCompanyAndAddressTemplate" />-->
    <!--<connector id="AUSPOST" name="AusPost" assembly="BigHand.Outline.Integration.AusPost.dll" typeName="BigHand.Outline.Integration.AusPost.AusPostContactSearch" templateName="NameCompanyAndAddressTemplate" />-->
  </wizardConnectors>

  <!-- The contact lookup connector used in the wizards (Multiple Addressees Control)-->
  <!-- The maximum value for each connector is 200. The minimum vlaue for each connector is 1. The default value for each connector is 200. -->
	<multipleAddresseesConnectors>
		<connector id="OUTLOOK" name="Outlook Connector" assembly="Iphelion.Outline.Integration.Outlook.dll" typeName="Iphelion.Outline.Integration.Outlook.OutlookContactSearchConnector" templateName="FullNameTemplate" />
		<!--<connector id="ADERANT" assembly="Iphelion.Outline.Integration.Aderant.dll" typeName="Iphelion.Outline.Integration.Aderant.AderantContactSearchConnector" templateName="FullNameTemplate" />-->
		<!--<connector id="AD" assembly="Iphelion.Outline.Core.dll" typeName="Iphelion.Outline.Core.Connectors.ActiveDirectoryContactSearchConnector" templateName="NameAndEmailTemplate"/>-->
	    <!--<sqlConnector id="SQL" assembly="Iphelion.Outline.Controls.dll" typeName="Iphelion.Outline.Controls.Search.GenericSqlContactSearchConnector" templateName="FullNameTemplate"
                   name="Contact SQL Search" connectionStringName="ContactSearchSqlConnector"
                   queryByIdFilename="ContactSqlConnectorQuery-ById.sql" queryByNameFilename="ContactSqlConnectorQuery-ByLastNamePaged.sql"
                   title ="Contact SQL Search" description ="Search by last name"/>-->
		<!--<connector id="DYNAMICS" name="Dynamics Connector" assembly="Iphelion.Outline.Integration.Dynamics.dll" typeName="Iphelion.Outline.Integration.Dynamics.DynamicsContactSearchConnector" templateName="FullNameTemplate" />-->
		<connector id="AUTHOR" name="Author contact search" assembly="Iphelion.Outline.Controls.dll" typeName="Iphelion.Outline.Core.Connectors.AuthorContactSearchConnector" templateName="NameAndEmailTemplate"/>
		<!--<connector id="ONEPLACE" name="OnePlace" assembly="BigHand.Outline.Integration.OnePlace.dll" typeName="BigHand.Outline.Integration.OnePlace.OnePlaceContactSearchConnector" templateName="FullNameTemplate" />-->
		<!--<connector id="AZURE" name="Azure Active Directory" assembly="BigHand.Outline.Integration.Azure.dll" typeName="BigHand.Outline.Integration.Azure.AzureAdContactSearchConnector" templateName="FullNameTemplate" />-->
		<!--<connector id="INTERACTION" name="InterAction" assembly="Iphelion.Outline.Integration.InterAction.dll" typeName="Iphelion.Outline.Integration.InterAction.InterActionContactSearchConnector" templateName="FullNameTemplate" />-->
	</multipleAddresseesConnectors>



	<!-- The connector used to search matter numbers-->
  <clientSearchConnectors>
    <!--<connector id="WORKSITE" assembly="Iphelion.Outline.Integration.WorkSite.dll" typeName="Iphelion.Outline.Integration.WorkSite.WorkSiteClientSearchConnector" />-->
  </clientSearchConnectors>

  <!-- The connector used to search matter numbers-->
  <matterSearchConnectors>
    <!--<connector id="WORKSITE" assembly="Iphelion.Outline.Integration.WorkSite.dll" typeName="Iphelion.Outline.Integration.WorkSite.WorkSiteMatterSearchConnector" />-->
  </matterSearchConnectors>

  <fieldMappings>
    <fieldMap typeName="Iphelion.Outline.Integration.Dynamics.DynamicsContactSearchConnector">
      <idProperty name="contactid" entity="contact" />
      <fullNameProperty name="fullname" entity="contact" />
      <titleProperty name="tre_prefix" entity="contact" />
      <initialsProperty name="" entity="" />
      <firstNameProperty name="firstname" entity="contact" />
      <middleNameProperty name="middlename" entity="contact" />
      <lastNameProperty name="lastname" entity="contact" />
      <suffixProperty name="suffix" entity="contact" />
      <addressProperty name="address1_composite" entity="contact" />
      <countryProperty name="address1_country" entity="contact" />
      <employeeIdProperty name="" entity="" />
      <jobTitleProperty name="jobtitle" entity="contact" />
      <companyProperty name="name" entity="account" />
      <departmentProperty name="department" entity="contact" />
      <officeProperty name="" entity="" />
      <phoneNumberProperty name="telephone1" entity="contact" />
      <mobileNumberProperty name="mobilephone" entity="contact" />
      <faxNumberProperty name="fax" entity="contact" />
      <emailProperty name="emailaddress1" entity="contact" />
      <salutationProperty name="salutation" entity="contact" />
    </fieldMap>
  </fieldMappings>

	<onePlaceSearchConnector>
		<onePlaceSettings url="" rowsLimit="10" />
		<contactEntry viewId="">
			<query>
				<filter field="" value="" group="Id"/>
			</query>
			<map>
				<property name="account" field=""/>
				<property name="firstName" field="First Name"/>
				<property name="surname" field="Last Name"/>
				<property name="role" field=""/>
				<property name="department" field=""/>
				<property name="phoneNumber" field="Main Phone"/>
				<property name="alternativeNumber" field=""/>
				<property name="faxNumber" field=""/>
				<property name="email" field="Email"/>
				<property name="employeeId" field="EntryId"/>
				<property name="office" field=""/>
				<property name="initials" field=""/>
				<property name="title" field=""/>
				<property name="middleName" field=""/>
				<property name="company" field=""/>
				<property name="address" field="Correspondence Address"/>
				<property name="country" field=""/>
				<property name="fullName" field="Full Name"/>
				<property name="addressee" field="Addressee"/>
				<property name="salutation" field="Salutation"/>
				<property name="barRegistration" field=""/>
			</map>
		</contactEntry>
		<matterContactEntry viewId="" >
			<query>
				<filter field="" value="" group="Id"/>
			</query>
			<map>
				<property name="account" field=""/>
				<property name="firstName" field="First Name"/>
				<property name="surname" field="Last Name"/>
				<property name="role" field=""/>
				<property name="department" field=""/>
				<property name="phoneNumber" field="Main Phone"/>
				<property name="alternativeNumber" field=""/>
				<property name="faxNumber" field=""/>
				<property name="email" field="Email"/>
				<property name="employeeId" field="EntryId"/>
				<property name="office" field=""/>
				<property name="initials" field=""/>
				<property name="title" field=""/>
				<property name="middleName" field=""/>
				<property name="company" field=""/>
				<property name="address" field="Correspondence Address"/>
				<property name="country" field=""/>
				<property name="fullName" field="Full Name"/>
				<property name="addressee" field="Addressee"/>
				<property name="salutation" field="Salutation"/>
				<property name="barRegistration" field=""/>
			</map>
		</matterContactEntry>
		<lookups>
			<lookup name="Matter" viewId="">
				<query>
					<filter field="" value="" group="Id"/>
				</query>
				<map>
					<property name="EntryId" field="EntryId"/>
					<property name="MatterId" field="Matter ID"/>
				</map>
			</lookup>
		</lookups>
	</onePlaceSearchConnector>

</search>