<?xml version="1.0" encoding="utf-8"?>
<search>
  <adSearchConnector>
    <ldapSettings useRoot="true" path="" pathFilter="" filter="(&amp;(objectClass=user)(objectCategory=person)(sn={0}*)(!(userAccountControl:1.2.840.113556.1.4.803:=2)){1})" maxResults="50"/>
    <accountProperty name="sAMAccountName" format="None" include="true"/>
    <firstnameProperty name="givenName" format="None" include="true"/>
    <surnameProperty name="sn" format="None" include="true"/>
    <roleProperty name="title" format="None" include="true"/>
    <departmentProperty name="department" format="None" include="true"/>
    <phoneNumberProperty name="telephoneNumber" format="None" include="true"/>
    <alternativeNumberProperty name="mobile" format="None" include="true"/>
    <faxNumberProperty name="facsimileTelephoneNumber" format="None" include="true"/>
    <emailProperty name="mail" format="Lowercase" include="true"/>
    <employeeIdProperty name="" format="None" include="false"/>
    <officeProperty name="physicalDeliveryOfficeName" format="None" include="true"/>
    <initialsProperty name="initials" format="None" include="true"/>
    <titleProperty name="personalTitle" format="None" include="true"/>
    <middleNameProperty name="middleName" format="None" include="true"/>
    <companyProperty name="company" format="None" include="true"/>
    <addressProperty name="streetAddress|l|st|postalCode" format="None" include="true"/>
    <countryProperty name="co" format="None" include="true"/>
    <barRegistrationProperty name="" format="None" include="false"/>
  </adSearchConnector>

  <azureAdSearchConnector>
	  <azureSettings clientId="" tenantId="" redirectUrl="" scope=""/>
	  <accountProperty mapFrom="userPrincipalName"/>
	  <!-- <accountProperty mapFrom="onPremisesSamAccountName"/> -->
	  <fullNameProperty mapFrom="displayName"/>
	  <firstnameProperty mapFrom="givenName"/>
	  <surnameProperty mapFrom="surname"/>
	  <roleProperty mapFrom="jobTitle"/>
	  <departmentProperty mapFrom="department"/>
	  <phoneNumberProperty mapFrom="businessPhones"/>
	  <alternativeNumberProperty mapFrom="mobilePhone"/>
	  <faxNumberProperty mapFrom="faxNumber"/>
	  <emailProperty mapFrom="mail"/>
	  <employeeIdProperty mapFrom="employeeId"/>
	  <officeProperty mapFrom="officeLocation"/>
	  <initialsProperty mapFrom=""/>
	  <titleProperty mapFrom=""/>
	  <middleNameProperty mapFrom=""/>
	  <companyProperty mapFrom="companyName"/>
	  <addressProperty mapFrom="address"/>
	  <countryProperty mapFrom="country"/>
	  <barRegistrationProperty mapFrom=""/>
  </azureAdSearchConnector>

  <ausPostSearchConnector>
    <ausPostSettings url="" apiKey=""/>
  </ausPostSearchConnector>

  <!-- the contact connector used when creating authors -->
  <authorConnectors>
    <connector id="AD" assembly="Iphelion.Outline.Controls.dll" typeName="Iphelion.Outline.Controls.Search.ActiveDirectoryContactSearch"/>
    <!--<connector id="AZURE" assembly="BigHand.Outline.Integration.Azure.dll" typeName="BigHand.Outline.Integration.Azure.AzureAdContactSearch"/>-->
    <!--<connector id="WORKSITE" assembly="Iphelion.Outline.Integration.WorkSite.dll" typeName="Iphelion.Outline.Integration.WorkSite.WorkSiteUserSearch"/>-->
    <!--<connector id="OUTLOOK" assembly="Iphelion.Outline.Integration.Outlook.dll" typeName="Iphelion.Outline.Integration.Outlook.OutlookContactSearch" />-->
  </authorConnectors>

  <coiSystemConnectors>
    <connector id="DIRECTORYENTRY" assembly="Iphelion.Outline.Core.dll" typeName="Iphelion.Outline.Core.Connectors.DirectoryEntryContactSearchConnector"/>
  </coiSystemConnectors>

  <!-- The contact lookup connector used in the wizards (address controls)-->
  <wizardConnectors>
    <!--<connector id="IAREST" 
	    assembly="Iphelion.Outline.Integration.InterAction.dll" 
		typeName="Iphelion.Outline.Integration.InterAction.InterActionRestContactSearch" >
