    <connector id="OUTLOOK" name="Outlook Connector" assembly="Iphelion.Outline.Integration.Outlook.dll" typeName="Iphelion.Outline.Integration.Outlook.OutlookContactSearch" templateName="NameCompanyAndAddressTemplate" />
    <!--<connector id="OUTLOOKAB" name="Outlook Address Book" assembly="Iphelion.Outline.Integration.Outlook.dll" typeName="Iphelion.Outline.Integration.Outlook.OutlookAddressBookSearch" 
               paramDefinitionTypeName="Iphelion.Outline.Integration.Outlook.OutlookAddressBookSearchParameterDefinition" />-->
    <!--<connector id="ADERANT" assembly="Iphelion.Outline.Integration.Aderant.dll" typeName="Iphelion.Outline.Integration.Aderant.AderantContactSearch" templateName="NameCompanyAndAddressTemplate" />-->
    <!--<connector id="AD" assembly="Iphelion.Outline.Controls.dll" typeName="Iphelion.Outline.Controls.Search.ActiveDirectoryContactSearch"/>-->
